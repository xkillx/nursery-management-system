APP_ENV=local
API_PORT=8080
API_BASE_PATH=/api/v1

DATABASE_URL=postgres://postgres:postgres@localhost:5432/nursery_management?sslmode=disable

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=720

EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.local

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

WEB_BASE_URL=http://localhost:4200

PASSWORD_RESET_TOKEN_SECRET=replace-with-strong-secret
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

INVITE_TOKEN_SECRET=replace-with-strong-secret
INVITE_TOKEN_TTL_HOURS=168
